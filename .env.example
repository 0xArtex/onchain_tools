# Copy to .env and fill secrets for local Docker deployment.

# Redis is provided by docker-compose. Override only if not using compose.
# The launch-monitor service uses host networking on Linux, so Redis is reached
# via the host loopback port published by the redis service.
REDIS_URL=redis://127.0.0.1:6379/0

# Optional: existing raw scanner Telegram group alerts.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ENABLE_TELEGRAM=true

# Optional but recommended for follower/profile enrichment inside the scanner.
# Hermes will still do deeper X research after receiving the alert.
TWITTERAPI_KEY=

# Forward every fired scanner alert to Hermes running on this same host.
# docker-compose uses host networking for the scanner, so 127.0.0.1 is the host.
ABOT_WEBHOOK_URL=http://127.0.0.1:8644/webhooks/onchain-alerts

# HMAC secret for Hermes /webhooks/<route>. Required for Hermes webhooks unless
# the route explicitly uses INSECURE_NO_AUTH for local testing.
ABOT_WEBHOOK_SECRET=

# Legacy OpenClaw/a-bot proxy token. Leave empty for native Hermes webhooks.
ABOT_PROXY_TOKEN=

# Scanner/runtime settings.
LOG_LEVEL=INFO

# ── Launch monitor tuning (all optional; defaults shown) ──────────────────
# Chains to scan. All are ON by default — set one to false to skip that chain.
# ROBINHOOD = Robinhood Chain (the Robinhood Arbitrum-Orbit L2).
SOLANA=true
BASE=true
BSC=true
ROBINHOOD=true

# Minimum pool liquidity (USD) for a token to fire an alert.
LAUNCH_MIN_LIQUIDITY=6000

# Market-cap band (USD). 0 disables the check. Both off by default.
LAUNCH_MIN_MARKET_CAP=0
LAUNCH_MAX_MARKET_CAP=0

# Social requirements / minimums.
LAUNCH_REQUIRE_TWITTER=true
LAUNCH_REQUIRE_WEBSITE=false
LAUNCH_MIN_TWITTER_FOLLOWERS=0

# Scan timing. POLL_SECONDS = seconds between scans; LOOKBACK_HOURS = how new a
# pair must be; TOP_N_FOR_NO_TIME = how many top-liquidity pairs to keep when a
# pair has no creation timestamp.
LAUNCH_POLL_SECONDS=30
LAUNCH_LOOKBACK_HOURS=1
LAUNCH_TOP_N_FOR_NO_TIME=50

# ── Smart-wallet activity filter (optional; OFF unless wallets are listed) ──
# Only alert on tokens that tracked "smart money" wallets currently hold.
# List Solana and/or EVM (0x…) addresses, comma/space/newline separated.
# Leave empty to disable (default) — the monitor behaves as before.
LAUNCH_SMART_WALLETS=
# How many of your wallets must hold the token to alert. 0 -> defaults to 1
# once wallets are listed. Optionally also require a percentage of them.
LAUNCH_MIN_SMART_WALLETS=0
LAUNCH_MIN_SMART_WALLET_PCT=0
# How often (seconds) to refresh wallet holdings.
LAUNCH_SMART_WALLET_REFRESH_SECONDS=60
# Holdings data providers (required only if you list wallets on that chain):
#   Solana -> Helius   |   Base/BSC/Robinhood -> Alchemy
HELIUS_API_KEY=
ALCHEMY_API_KEY=

# ── CabalSpy labeled-wallet enrichment (optional; OFF without key) ─────────
# Score each alert by which CabalSpy-labeled KOL/smart wallets already bought
# the token (0-100 legitimacy score + buyer list in the alert). Free key:
# https://apidashboard.cabalspy.xyz/register (10k credits/mo; 1 alert = 10).
CABALSPY_API_KEY=
# Chains to enrich (launch-monitor ids). Start small: robinhood only.
CABALSPY_CHAINS=robinhood
# Restrict to one label (kol|smart|whale). Empty = all labeled wallets.
CABALSPY_WALLET_TYPE=
# Require ≥N labeled buyers to alert at all. 0 = enrich only, never filter.
# NOTE: with the gate on, a pending token is re-checked as its 5-min cache
# expires, up to CABALSPY_MAX_CHECKS metered calls (10 credits each).
CABALSPY_MIN_BUYERS=0
CABALSPY_MAX_CHECKS=6
# Newest labeled transactions examined per token (REST limit param).
CABALSPY_TX_LIMIT=100

# ── Claude Code analysis (optional; OFF by default) ────────────────────────
# Second-stage token research through the LOCAL Claude Code CLI (headless
# `claude -p`), parallel to the Hermes webhook. Uses your local Claude login;
# every alert spawns a billed session, bounded by the caps below. The verdict
# (SKIP/WATCH/APE/BUY) is replied to the Telegram alert and published on the
# `token_analysis` MQ channel.
CLAUDE_CODE_ENABLED=false
# claude-opus-4-8 (default) or claude-fable-5; aliases opus/fable also work.
CLAUDE_CODE_MODEL=claude-opus-4-8
# Hard caps per analysis run, plus a backlog cap: when MAX_PENDING analyses
# are already queued/running, further alerts are skipped (a verdict hours late
# is full cost for zero utility).
CLAUDE_CODE_MAX_BUDGET_USD=1.0
CLAUDE_CODE_TIMEOUT_SECONDS=600
CLAUDE_CODE_MAX_CONCURRENT=1
CLAUDE_CODE_MAX_PENDING=3
# Headless-safe permissions: dontAsk auto-denies anything not allow-listed,
# so a run can never hang waiting for a permission prompt.
# SECURITY: keep the allow-list web-only. The prompt contains untrusted token
# metadata; adding Read/Glob/Grep would let a prompt-injected session read
# local files (this .env holds private keys!) with WebFetch to exfiltrate.
CLAUDE_CODE_PERMISSION_MODE=dontAsk
CLAUDE_CODE_ALLOWED_TOOLS=WebSearch,WebFetch
# Optional: reasoning effort (low|medium|high|xhigh|max), CLI binary, workdir.
CLAUDE_CODE_EFFORT=
CLAUDE_CODE_BIN=claude
CLAUDE_CODE_WORKDIR=

# Optional buy-button/private-key settings. Leave empty unless you intentionally enable buys.
SOLANA_PRIVATE_KEY=
EVM_PRIVATE_KEY=
BUY_AMOUNT_USD=50
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
