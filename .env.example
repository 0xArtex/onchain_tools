# Copy to .env and fill secrets for local Docker deployment.

# Redis is provided by docker-compose. Override only if not using compose.
# The launch-monitor service uses host networking on Linux, so Redis is reached
# via the host loopback port published by the redis service.
REDIS_URL=redis://127.0.0.1:6379/0

# Optional: existing raw scanner Telegram group alerts.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ENABLE_TELEGRAM=true

# Optional but recommended for follower/profile enrichment inside the scanner.
# Hermes will still do deeper X research after receiving the alert.
TWITTERAPI_KEY=

# Forward every fired scanner alert to Hermes running on this same host.
# docker-compose uses host networking for the scanner, so 127.0.0.1 is the host.
ABOT_WEBHOOK_URL=http://127.0.0.1:8644/webhooks/onchain-alerts

# HMAC secret for Hermes /webhooks/<route>. Required for Hermes webhooks unless
# the route explicitly uses INSECURE_NO_AUTH for local testing.
ABOT_WEBHOOK_SECRET=

# Legacy OpenClaw/a-bot proxy token. Leave empty for native Hermes webhooks.
ABOT_PROXY_TOKEN=

# Scanner/runtime settings.
LOG_LEVEL=INFO

# Optional buy-button/private-key settings. Leave empty unless you intentionally enable buys.
SOLANA_PRIVATE_KEY=
EVM_PRIVATE_KEY=
BUY_AMOUNT_USD=50
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
